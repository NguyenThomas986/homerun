# ── REQUIRED: aligner + genome (no genome is assumed) ────────────────────────
export CSRNA_ALIGNER="star"          # "star" (default) or "hisat2"
# Path to the index for the CHOSEN aligner:
#   star   → the STAR --genomeDir DIRECTORY
#   hisat2 → the HISAT2 -x index PREFIX (e.g. /path/idx/genome  →  genome.1.ht2 ...)
export CSRNA_GENOME_INDEX="/data/lab/duttke/personal/tnguyen/projects/TestRun4/STARIndex"
export CSRNA_STARINDEX_URL="https://ftp.ncbi.nlm.nih.gov/geo/series/GSE287nnn/GSE287021/suppl/GSE287021%5FSTARIndex%5Fhg38.tar.gz"
export CSRNA_GENOME="hg38"   # HOMER -genome for tagdirs/TSS

# ── Project + run settings ───────────────────────────────────────────────────
export CSRNA_PROJECT="/data/lab/duttke/personal/tnguyen/projects/TestRun4"
export CSRNA_COPY_SRC="/data/lab/duttke/personal/tnguyen/projects/K562_Data/*.fastq.gz"              # optional cp glob into RawData/ ("" to skip)
export CSRNA_ARRAY_THROTTLE="16"       # max array tasks running at once

# ── Cluster ──────────────────────────────────────────────────────────────────
export CSRNA_CONDA_MODULE="anaconda3"
export CSRNA_CONDA_ENV="miniComputer"
export CSRNA_PARTITION="kamiak"
export CSRNA_EMAIL="thomas.nguyen11@wsu.edu"
