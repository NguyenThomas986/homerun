# ── REQUIRED: aligner + genome (no genome is assumed) ────────────────────────
export CSRNA_ALIGNER="star"          # "star" (default) or "hisat2"
# Path to the index for the CHOSEN aligner:
#   star   → the STAR --genomeDir DIRECTORY
#   hisat2 → the HISAT2 -x index PREFIX (e.g. /path/idx/genome  →  genome.1.ht2 ...)
export CSRNA_GENOME_INDEX="/path/to/STARIndex"
export CSRNA_STARINDEX_URL=""        # URL to auto-download STARIndex tarball if missing
export CSRNA_GENOME="hg38"          # HOMER -genome for tagdirs/TSS

# ── Project + run settings ───────────────────────────────────────────────────
export CSRNA_PROJECT="/path/to/your/project"
export CSRNA_COPY_SRC=""             # optional glob to copy FASTQs into RawData/ ("" to skip)
export CSRNA_ARRAY_THROTTLE="16"     # max array tasks running at once

# ── Cluster ──────────────────────────────────────────────────────────────────
export CSRNA_CONDA_MODULE="anaconda3"
export CSRNA_CONDA_ENV="your_conda_env"
export CSRNA_PARTITION="your_partition"
export CSRNA_EMAIL=""                # email for SLURM job notifications ("" to disable)
